@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6" Class="ml-3">🏋️ GymClassBooking</MudText>
        <MudSpacer />
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.FitnessCenter">Classes</MudNavLink>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
